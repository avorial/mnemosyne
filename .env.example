# App
SECRET_KEY=replace-with-32-byte-hex-from-secrets-randbits
MAGIC_LINK_EMAIL=patricthomas@gmail.com
BASE_URL=https://mnemosyne.avorial.com

# Storage (paths inside the container, all under the mounted /mnt/mnemosyne volume)
VAULT_PERSONAL_PATH=/mnt/mnemosyne/vault-notes
VAULT_WORK_PATH=/mnt/mnemosyne/vault-work
SECRETS_PATH=/mnt/mnemosyne/secrets
DB_PATH=/mnt/mnemosyne/mnemosyne.db

# Git (used by services/vault.py when committing into the vault checkouts)
GIT_SSH_COMMAND=ssh -F /mnt/mnemosyne/secrets/ssh_config

# SMTP for magic-link emails. If unset, the link is printed to the app log (dev fallback).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Asana (v0.5)
ASANA_PAT_FILE=/mnt/mnemosyne/secrets/asana_pat

# Calendar widget. Personal workspace = Google, work workspace = Microsoft 365.
# Refresh tokens are stored under SECRETS_PATH after the in-app connect flow.
# IANA timezone used for event display and day boundaries.
TIMEZONE=America/Denver

# Google Calendar: OAuth web client from Google Cloud Console.
# Register redirect URI: {BASE_URL}/widgets/calendar/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft 365: app registration in Entra (delegated Calendars.Read,
# offline_access, User.Read). Register redirect URI:
# {BASE_URL}/widgets/calendar/ms/callback
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=

# GitHub activity widget: single-line PAT file (like the Asana PAT).
GITHUB_PAT_FILE=/mnt/mnemosyne/secrets/github_pat
